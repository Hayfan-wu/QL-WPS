# ===================== 青龙面板 Open API 配置 =====================
# WPS 插件会把 Cookie 写入这个青龙面板
QL_URL=http://127.0.0.1:5700
QL_CLIENT_ID=your_client_id
QL_CLIENT_SECRET=your_client_secret

# ===================== WPS 脚本路径（可选） =====================
# 脚本在 QL-WPS 仓库内，一般无需修改；若改为其他路径请填绝对路径
WPS_SCRIPT_PATH=wps_auto.py

# ===================== WXPusher 推送配置（可选） =====================
WXPUSHER_APP_TOKEN=
WXPUSHER_UID=
